/* 全局样式变量 */
page {
  --bg-primary: #0a0e17;
  --bg-secondary: #111827;
  --bg-card: #161d2e;
  --accent-green: #00ff88;
  --accent-blue: #00b4d8;
  --accent-red: #ff3366;
  --accent-yellow: #ffd700;
  --accent-purple: #a855f7;
  --text-primary: #e0e0e0;
  --text-secondary: #6b7280;
  --text-dim: #374151;
  --border-color: #1e293b;
  --border-glow: rgba(0, 255, 136, 0.2);
  --radius: 12rpx;
  --radius-lg: 16rpx;

  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用工具类 */
.container {
  padding: 32rpx;
}

.card {
  background: var(--bg-secondary);
  border: 1rpx solid var(--border-color);
  border-radius: var(--radius);
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.card-glow {
  background: var(--bg-secondary);
  border: 1rpx solid var(--border-glow);
  border-radius: var(--radius);
  padding: 24rpx;
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.1);
}

/* 按钮 */
.btn-primary {
  background: var(--accent-green);
  color: var(--bg-primary);
  border-radius: 8rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  padding: 0;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.97);
  box-shadow: 0 0 30rpx rgba(0, 255, 136, 0.4);
}

.btn-secondary {
  background: transparent;
  color: var(--accent-green);
  border: 1rpx solid var(--accent-green);
  border-radius: 8rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  padding: 0;
  box-sizing: border-box;
  transition: all 0.2s ease;
}

.btn-secondary:active {
  background: rgba(0, 255, 136, 0.1);
}

.btn-danger {
  background: transparent;
  color: var(--accent-red);
  border: 1rpx solid var(--accent-red);
  border-radius: 8rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  padding: 0;
  box-sizing: border-box;
}

.btn-danger:active {
  background: rgba(255, 51, 102, 0.1);
}

/* 文字颜色 */
.text-green { color: var(--accent-green); }
.text-blue { color: var(--accent-blue); }
.text-red { color: var(--accent-red); }
.text-yellow { color: var(--accent-yellow); }
.text-purple { color: var(--accent-purple); }
.text-secondary { color: var(--text-secondary); }
.text-dim { color: var(--text-dim); }
.text-center { text-align: center; }
.text-mono { font-family: 'Courier New', monospace; }

/* 装饰元素 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--border-color), transparent);
  margin: 32rpx 0;
}

.divider-glow {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--accent-green), transparent);
  margin: 32rpx 0;
  opacity: 0.5;
}

/* 加载动画 */
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.2); }
  50% { box-shadow: 0 0 30rpx rgba(0, 255, 136, 0.4); }
}

.pulse {
  animation: pulse 2s infinite;
}

.glow {
  animation: glow 2s infinite;
}

/* 徽章 */
.badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  border-radius: 4rpx;
  font-weight: bold;
}

.badge-green {
  background: rgba(0, 255, 136, 0.15);
  color: var(--accent-green);
  border: 1rpx solid rgba(0, 255, 136, 0.3);
}

.badge-red {
  background: rgba(255, 51, 102, 0.15);
  color: var(--accent-red);
  border: 1rpx solid rgba(255, 51, 102, 0.3);
}

.badge-blue {
  background: rgba(0, 180, 216, 0.15);
  color: var(--accent-blue);
  border: 1rpx solid rgba(0, 180, 216, 0.3);
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: var(--bg-secondary);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--accent-green);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 工具提示 */
.tooltip {
  font-size: 22rpx;
  color: var(--text-secondary);
  padding: 8rpx 0;
}

/* Flex 工具 */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.gap-sm { gap: 8rpx; }
.gap-md { gap: 16rpx; }
.gap-lg { gap: 24rpx; }
