@import '../../styles/theme.wxss';

.intro-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 背景效果 */
.bg-effects {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.scanline {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2rpx,
    rgba(0, 255, 136, 0.03) 2rpx,
    rgba(0, 255, 136, 0.03) 4rpx
  );
  animation: scanlineMove 8s linear infinite;
}

@keyframes scanlineMove {
  0% { transform: translateY(0); }
  100% { transform: translateY(100vh); }
}

.matrix-rain {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background:
    radial-gradient(circle at 20% 30%, rgba(0, 255, 136, 0.05) 0%, transparent 50%),
    radial-gradient(circle at 80% 70%, rgba(0, 180, 216, 0.05) 0%, transparent 50%);
}

/* 故事内容 */
.story-container {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 60rpx;
  position: relative;
  z-index: 1;
}

.story-content {
  width: 100%;
  max-width: 600rpx;
}

.story-line {
  opacity: 0;
  transform: translateY(30rpx);
  margin-bottom: 32rpx;
  transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
}

.line-visible {
  opacity: 1;
  transform: translateY(0);
}

.line-text {
  font-size: 36rpx;
  color: var(--text-primary);
  line-height: 1.8;
  letter-spacing: 4rpx;
  font-weight: 300;
}

.text-highlight {
  color: var(--accent-green);
  font-size: 42rpx;
  font-weight: bold;
  text-shadow:
    0 0 10rpx rgba(0, 255, 136, 0.5),
    0 0 20rpx rgba(0, 255, 136, 0.3),
    0 0 40rpx rgba(0, 255, 136, 0.1);
  animation: textGlow 2s ease-in-out infinite;
}

@keyframes textGlow {
  0%, 100% {
    text-shadow:
      0 0 10rpx rgba(0, 255, 136, 0.5),
      0 0 20rpx rgba(0, 255, 136, 0.3),
      0 0 40rpx rgba(0, 255, 136, 0.1);
  }
  50% {
    text-shadow:
      0 0 15rpx rgba(0, 255, 136, 0.7),
      0 0 30rpx rgba(0, 255, 136, 0.5),
      0 0 60rpx rgba(0, 255, 136, 0.2);
  }
}

/* 进度条 */
.progress-container {
  padding: 40rpx 60rpx;
  position: relative;
  z-index: 1;
}

.progress-bar {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 3rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-green), var(--accent-blue));
  border-radius: 3rpx;
  transition: width 0.1s linear;
  box-shadow: 0 0 10rpx rgba(0, 255, 136, 0.5);
}

.progress-text {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: var(--text-secondary);
  font-family: monospace;
  letter-spacing: 2rpx;
}

/* 按钮区域 */
.button-area {
  padding: 40rpx 60rpx 80rpx;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.btn-skip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: transparent;
  border: 1rpx solid var(--text-secondary);
  color: var(--text-secondary);
  font-size: 28rpx;
  padding: 20rpx 60rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
}

.btn-skip::after {
  border: none;
}

.btn-skip:active {
  background: rgba(255, 255, 255, 0.05);
  border-color: var(--text-primary);
  color: var(--text-primary);
}

.skip-icon {
  font-size: 24rpx;
}

.btn-start {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: var(--accent-green);
  color: var(--bg-primary);
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 80rpx;
  border-radius: 8rpx;
  animation: buttonPulse 2s ease-in-out infinite;
}

.btn-start::after {
  border: none;
}

.btn-start:active {
  transform: scale(0.95);
}

@keyframes buttonPulse {
  0%, 100% {
    box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.3);
  }
  50% {
    box-shadow: 0 0 40rpx rgba(0, 255, 136, 0.6);
  }
}

.start-icon {
  font-size: 36rpx;
}

/* 底部装饰 */
.footer-decoration {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 1;
}

.footer-text {
  font-size: 20rpx;
  color: var(--text-secondary);
  font-family: monospace;
  letter-spacing: 4rpx;
  opacity: 0.5;
}
