@import '../../styles/theme.wxss';

.intro-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 背景效果 */
.bg-effects {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.grid-lines {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px);
  background-size: 50rpx 50rpx;
  animation: gridMove 20s linear infinite;
}

@keyframes gridMove {
  0% { transform: translate(0, 0); }
  100% { transform: translate(50rpx, 50rpx); }
}

.glow-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.15;
}

.orb-1 {
  width: 400rpx;
  height: 400rpx;
  background: var(--accent-green);
  top: 20%;
  left: -10%;
  animation: orbFloat1 15s ease-in-out infinite;
}

.orb-2 {
  width: 300rpx;
  height: 300rpx;
  background: var(--accent-blue);
  bottom: 20%;
  right: -5%;
  animation: orbFloat2 12s ease-in-out infinite;
}

@keyframes orbFloat1 {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(60rpx, 40rpx); }
}

@keyframes orbFloat2 {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-40rpx, -30rpx); }
}

/* 故事内容 */
.story-container {
  flex: 1;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.story-scroll {
  height: 100%;
  width: 100%;
}

.story-content {
  padding: 120rpx 80rpx 60rpx;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.story-group {
  margin-bottom: 60rpx;
  animation: groupFadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

@keyframes groupFadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.story-line {
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}

.line-text {
  font-size: 38rpx;
  color: var(--text-primary);
  line-height: 1.8;
  letter-spacing: 6rpx;
  font-weight: 300;
}

.cursor {
  display: inline-block;
  color: var(--accent-green);
  font-size: 38rpx;
  animation: cursorBlink 0.8s ease-in-out infinite;
  margin-left: 2rpx;
}

@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* 文本类型样式 */
.group-normal .line-text {
  color: var(--text-primary);
}

.group-highlight .line-text {
  color: var(--accent-green);
  font-size: 48rpx;
  font-weight: bold;
  text-shadow:
    0 0 20rpx rgba(0, 255, 136, 0.6),
    0 0 40rpx rgba(0, 255, 136, 0.3);
}

.group-highlight .cursor {
  color: var(--accent-green);
  text-shadow: 0 0 20rpx rgba(0, 255, 136, 0.6);
}

.group-warning .line-text {
  color: var(--accent-yellow);
  text-shadow: 0 0 15rpx rgba(255, 215, 0, 0.3);
}

.group-warning .cursor {
  color: var(--accent-yellow);
}

.group-mission .line-text {
  color: var(--accent-green);
  font-size: 44rpx;
  font-weight: bold;
  letter-spacing: 8rpx;
  text-shadow:
    0 0 15rpx rgba(0, 255, 136, 0.5),
    0 0 30rpx rgba(0, 255, 136, 0.3);
}

.group-mission .cursor {
  color: var(--accent-green);
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.5);
}

/* 进度条 */
.progress-container {
  padding: 40rpx 80rpx 30rpx;
  position: relative;
  z-index: 1;
}

.progress-wrapper {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.progress-track {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 4rpx;
  overflow: visible;
  position: relative;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-green), var(--accent-blue));
  border-radius: 4rpx;
  transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.progress-glow {
  position: absolute;
  top: -8rpx;
  width: 20rpx;
  height: 24rpx;
  background: var(--accent-green);
  border-radius: 50%;
  filter: blur(10rpx);
  opacity: 0.6;
  transform: translateX(-50%);
  transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-family: monospace;
  letter-spacing: 2rpx;
}

.progress-percent {
  font-size: 22rpx;
  color: var(--accent-green);
  font-family: monospace;
  font-weight: bold;
}

/* 按钮区域 */
.button-area {
  padding: 30rpx 80rpx 100rpx;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.btn-skip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  color: var(--text-secondary);
  font-size: 26rpx;
  padding: 18rpx 50rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.btn-skip::after {
  border: none;
}

.btn-skip:active {
  background: rgba(255, 255, 255, 0.05);
  border-color: var(--accent-green);
  color: var(--accent-green);
}

.btn-start {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  background: linear-gradient(135deg, var(--accent-green), #00cc6a);
  color: var(--bg-primary);
  font-size: 34rpx;
  font-weight: bold;
  padding: 28rpx 100rpx;
  border-radius: 12rpx;
  letter-spacing: 4rpx;
  transition: all 0.3s ease;
  box-shadow: 0 0 30rpx rgba(0, 255, 136, 0.4);
}

.btn-start::after {
  border: none;
}

.btn-start:active {
  transform: scale(0.96);
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.3);
}

.start-text {
  position: relative;
}

.start-arrow {
  font-size: 40rpx;
  animation: arrowPulse 1.5s ease-in-out infinite;
}

@keyframes arrowPulse {
  0%, 100% { transform: translateX(0); opacity: 1; }
  50% { transform: translateX(8rpx); opacity: 0.7; }
}
