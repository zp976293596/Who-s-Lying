@import '../../styles/theme.wxss';

.intro-page {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-primary);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 背景效果 */
.bg-effects {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
}

.grid-lines {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image:
    linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px);
  background-size: 50rpx 50rpx;
  animation: gridMove 20s linear infinite;
}

@keyframes gridMove {
  0% { transform: translate(0, 0); }
  100% { transform: translate(50rpx, 50rpx); }
}

.glow-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80rpx);
  opacity: 0.15;
}

.orb-1 {
  width: 400rpx;
  height: 400rpx;
  background: var(--accent-green);
  top: 20%;
  left: -10%;
  animation: orbFloat1 15s ease-in-out infinite;
}

.orb-2 {
  width: 300rpx;
  height: 300rpx;
  background: var(--accent-blue);
  bottom: 20%;
  right: -5%;
  animation: orbFloat2 12s ease-in-out infinite;
}

@keyframes orbFloat1 {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(60rpx, 40rpx); }
}

@keyframes orbFloat2 {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-40rpx, -30rpx); }
}

/* 故事内容 */
.story-container {
  flex: 1;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.story-content {
  padding: 120rpx 60rpx 60rpx;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.story-line {
  margin-bottom: 8rpx;
  display: flex;
  align-items: center;
  min-height: 44rpx;
  opacity: 0;
  transform: translateY(10rpx);
  transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

.story-line.line-active {
  opacity: 1;
  transform: translateY(0);
}

.story-line.line-done {
  opacity: 0.7;
  transform: translateY(0);
}

.line-text {
  font-size: 34rpx;
  color: var(--text-primary);
  line-height: 1.6;
  letter-spacing: 2rpx;
  font-weight: 300;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.08);
}

.cursor {
  display: inline-block;
  color: var(--accent-green);
  font-size: 34rpx;
  animation: cursorPulse 0.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  margin-left: 2rpx;
  text-shadow: 0 0 15rpx rgba(0, 255, 136, 0.6);
}

@keyframes cursorPulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.3;
  }
}

/* 进度条 */
.progress-container {
  padding: 30rpx 60rpx 20rpx;
  position: relative;
  z-index: 1;
}

.progress-wrapper {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  padding: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.05);
}

.progress-track {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 3rpx;
  overflow: visible;
  position: relative;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent-green), var(--accent-blue));
  border-radius: 3rpx;
  transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}

.progress-glow {
  position: absolute;
  top: -6rpx;
  width: 16rpx;
  height: 18rpx;
  background: var(--accent-green);
  border-radius: 50%;
  filter: blur(8rpx);
  opacity: 0.6;
  transform: translateX(-50%);
  transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.progress-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  font-family: monospace;
  letter-spacing: 2rpx;
}

.progress-percent {
  font-size: 20rpx;
  color: var(--accent-green);
  font-family: monospace;
  font-weight: bold;
}

/* 按钮区域 */
.button-area {
  padding: 20rpx 60rpx 80rpx;
  display: flex;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.btn-skip {
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  color: var(--text-secondary);
  font-size: 24rpx;
  padding: 16rpx 40rpx;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  font-family: monospace;
  letter-spacing: 2rpx;
}

.btn-skip::after {
  border: none;
}

.btn-skip:active {
  background: rgba(255, 255, 255, 0.05);
  border-color: var(--accent-green);
  color: var(--accent-green);
}

.btn-start {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(135deg, var(--accent-green), #00cc6a);
  color: var(--bg-primary);
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 80rpx;
  border-radius: 12rpx;
  letter-spacing: 4rpx;
  transition: all 0.3s ease;
  box-shadow: 0 0 30rpx rgba(0, 255, 136, 0.4);
}

.btn-start::after {
  border: none;
}

.btn-start:active {
  transform: scale(0.96);
  box-shadow: 0 0 20rpx rgba(0, 255, 136, 0.3);
}

.start-text {
  position: relative;
}

.start-arrow {
  font-size: 36rpx;
  animation: arrowPulse 1.5s ease-in-out infinite;
}

@keyframes arrowPulse {
  0%, 100% { transform: translateX(0); opacity: 1; }
  50% { transform: translateX(8rpx); opacity: 0.7; }
}
