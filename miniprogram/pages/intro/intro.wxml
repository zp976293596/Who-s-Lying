<view class="intro-page">
  <!-- 背景效果 -->
  <view class="bg-effects">
    <view class="grid-lines"></view>
    <view class="glow-orb orb-1"></view>
    <view class="glow-orb orb-2"></view>
  </view>

  <!-- 故事内容 -->
  <view class="story-container">
    <view class="story-content">
      <view
        class="story-group group-{{item.type}}"
        wx:for="{{displayedGroups}}"
        wx:key="index"
      >
        <view
          class="story-line"
          wx:for="{{item.lines}}"
          wx:for-item="line"
          wx:key="text"
        >
          <text class="line-text">{{line.displayText}}</text>
          <text class="cursor" wx:if="{{line.showCursor}}">▊</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 进度条 -->
  <view class="progress-container">
    <view class="progress-wrapper">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progress}}%"></view>
        <view class="progress-glow" style="left: {{progress}}%"></view>
      </view>
      <view class="progress-info">
        <text class="progress-label">{{isPlaying ? '数据传输' : isFinished ? '传输完成' : '初始化'}}</text>
        <text class="progress-percent">{{progressText}}%</text>
      </view>
    </view>
  </view>

  <!-- 按钮区域 -->
  <view class="button-area">
    <button class="btn-skip" bindtap="onSkip" wx:if="{{isPlaying}}">
      <text>跳过 ▶▶</text>
    </button>

    <button class="btn-start" bindtap="onStartGame" wx:if="{{isFinished}}">
      <text class="start-text">进入矩阵</text>
      <view class="start-arrow">→</view>
    </button>
  </view>
</view>
