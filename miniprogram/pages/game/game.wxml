<view class="container game-page">
  <!-- 顶部信息栏 -->
  <view class="game-header">
    <view class="round-info">
      <text class="round-label">第 {{round}}/{{maxRounds}} 轮</text>
      <text class="phase-badge badge badge-green">{{phase === 'answering' ? '答题中' : phase === 'revealing' ? '揭示中' : phase}}</text>
    </view>
    <view class="timer {{timeLeft <= 10 ? 'timer-warning' : ''}}" wx:if="{{phase === 'answering'}}">
      <text class="timer-value">{{timeLeft}}</text>
      <text class="timer-unit">秒</text>
    </view>
  </view>

  <!-- 嫌疑公示栏 -->
  <view class="suspect-board card">
    <text class="board-title">嫌疑指数</text>
    <view class="player-list">
      <view class="player-item" wx:for="{{players}}" wx:key="id" wx:if="{{item.alive}}">
        <text class="player-name">{{item.isHuman ? '你' : 'AI-' + item.personality}}</text>
        <view class="possibility-bar">
          <view class="possibility-fill" style="width: {{item.humanPossibility}}%"></view>
        </view>
        <text class="possibility-value {{item.humanPossibility >= 60 ? 'text-red' : ''}}">{{item.humanPossibility}}</text>
      </view>
    </view>
  </view>

  <!-- 答题阶段 -->
  <view class="question-area" wx:if="{{phase === 'answering' && question}}">
    <view class="question-type badge badge-blue">{{question.type}}</view>
    <text class="question-content">{{question.content}}</text>

    <view class="options-list">
      <view
        class="option-item {{selectedAnswer === item.label ? 'option-selected' : ''}}"
        wx:for="{{question.options}}"
        wx:key="label"
        bindtap="onSelectOption"
        data-answer="{{item.label}}"
      >
        <text class="option-label">{{item.label}}</text>
        <text class="option-text">{{item.text}}</text>
      </view>
    </view>

    <button class="btn-primary submit-btn" bindtap="onSubmitAnswer">
      {{selectedAnswer ? '提交答案 (' + selectedAnswer + ')' : '请先选择答案'}}
    </button>
  </view>

  <!-- 揭示阶段 -->
  <view class="reveal-area" wx:if="{{phase === 'revealing'}}">
    <!-- 正确答案 -->
    <view class="correct-answer card-glow">
      <text class="reveal-label">正确答案</text>
      <text class="answer-value text-green">{{correctAnswer}}</text>
      <view class="my-answer answer-wrong" wx:if="{{!myResult}}">
        <text>你的答案：未作答</text>
        <text class="result-icon">✗</text>
      </view>
      <view class="my-answer {{myResult.isCorrect ? 'answer-correct' : 'answer-wrong'}}" wx:elif="{{myResult}}">
        <text>你的答案：{{myResult.answer || '未作答'}}</text>
        <text class="result-icon">{{myResult.isCorrect ? '✓' : '✗'}}</text>
      </view>
    </view>

    <!-- 所有玩家作答情况 -->
    <view class="answers-list">
      <text class="list-title">作答分析</text>
      <view class="answer-item" wx:for="{{answerResults}}" wx:key="playerId">
        <view class="answer-header">
          <text class="player-name {{item.isHuman ? 'text-green' : ''}}">{{item.playerName}}</text>
          <text class="response-time">{{item.responseTimeStr}}</text>
        </view>
        <view class="answer-body">
          <text class="answer-choice">选择：{{item.answer || '未作答'}}</text>
          <text class="answer-result {{item.isCorrect ? 'text-green' : 'text-red'}}">
            {{item.isCorrect ? '✓ 正确' : '✗ 错误'}}
          </text>
        </view>
        <!-- 异常标记 -->
        <view class="anomaly-tags" wx:if="{{item.anomalies.length > 0}}">
          <text class="anomaly-tag" wx:for="{{item.anomalies}}" wx:for-item="anomaly" wx:key="*this">
            {{anomaly}}
          </text>
        </view>
      </view>
    </view>

    <!-- 进入讨论按钮 -->
    <button class="btn-primary next-btn" bindtap="onEnterDiscussion">
      进入讨论分析
    </button>
  </view>

  <!-- 讨论阶段 -->
  <view class="discussion-area" wx:if="{{phase === 'discussing'}}">
    <!-- 讨论倒计时 -->
    <view class="discussion-header">
      <text class="discussion-title">讨论分析</text>
      <view class="discussion-timer {{discussionTimeLeft <= 15 ? 'timer-warning' : ''}}">
        <text>{{discussionTimeLeft}}秒</text>
      </view>
    </view>

    <!-- 本轮作答数据汇总 -->
    <view class="answer-summary card">
      <text class="summary-title">本轮作答汇总</text>
      <view class="summary-stats">
        <view class="stat-item">
          <text class="stat-value text-green">{{correctCount}}</text>
          <text class="stat-label">答对</text>
        </view>
        <view class="stat-item">
          <text class="stat-value text-red">{{wrongCount}}</text>
          <text class="stat-label">答错</text>
        </view>
      </view>
    </view>

    <!-- 讨论消息列表 -->
    <scroll-view class="discussions-list" scroll-y scroll-into-view="{{'msg-' + discussions.length}}">
      <view class="discussion-item" wx:for="{{discussions}}" wx:key="_id" id="msg-{{index}}">
        <view class="msg-header">
          <text class="msg-sender {{item.isHuman ? 'text-green' : 'text-blue'}}">{{item.playerName}}</text>
          <text class="msg-time">{{item.timestampStr}}</text>
        </view>
        <view class="msg-content">
          <text>{{item.content}}</text>
        </view>
      </view>
      <!-- 空状态 -->
      <view class="empty-discussion" wx:if="{{discussions.length === 0}}">
        <text class="text-gray">暂无讨论发言...</text>
      </view>
    </scroll-view>

    <!-- 输入区域 -->
    <view class="discussion-input-area">
      <input
        class="discussion-input"
        placeholder="发表你的分析..."
        value="{{discussionInput}}"
        bindinput="onDiscussionInput"
        bindconfirm="onSendDiscussion"
        confirm-type="send"
      />
      <button class="btn-send" bindtap="onSendDiscussion">发送</button>
    </view>
  </view>

  <!-- 结束 -->
  <view class="finish-area" wx:if="{{phase === 'finished'}}">
    <view class="card">
      <text class="text-green" style="font-size: 36rpx; font-weight: bold;">游戏结束</text>
    </view>
    <button class="btn-secondary" bindtap="onFinishGame" style="margin-top: 40rpx;">返回首页</button>
  </view>
</view>
